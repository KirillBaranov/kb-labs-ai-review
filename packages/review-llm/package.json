{
  "name": "@kb-labs/review-llm",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "LLM-based analysis for KB Labs AI Review",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./architecture": {
      "import": "./dist/analyzers/architecture-analyzer.js",
      "types": "./dist/analyzers/architecture-analyzer.d.ts"
    },
    "./security": {
      "import": "./dist/analyzers/security-analyzer.js",
      "types": "./dist/analyzers/security-analyzer.d.ts"
    },
    "./naming": {
      "import": "./dist/analyzers/naming-analyzer.js",
      "types": "./dist/analyzers/naming-analyzer.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@kb-labs/review-contracts": "workspace:*",
    "@kb-labs/sdk": "link:../../../kb-labs-sdk/packages/sdk"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../kb-labs-devkit",
    "@types/node": "^24.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
