{
  "name": "@kb-labs/review-cli",
  "version": "0.4.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/review-contracts": "workspace:*",
    "@kb-labs/review-core": "workspace:*",
    "@kb-labs/sdk": "link:../../../../platform/kb-labs-sdk/packages/sdk",
    "@kb-labs/shared-cli-ui": "link:../../../../platform/kb-labs-shared/packages/shared-cli-ui",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "files": [
    "dist"
  ]
}
