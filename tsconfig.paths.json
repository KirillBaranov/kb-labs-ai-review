{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@kb-labs/review-contracts": [
        "packages/review-contracts/src/index.ts"
      ],
      "@kb-labs/review-contracts/*": [
        "packages/review-contracts/src/*"
      ],
      "@kb-labs/review-core": [
        "packages/review-core/src/index.ts"
      ],
      "@kb-labs/review-core/*": [
        "packages/review-core/src/*"
      ],
      "@kb-labs/review-heuristic": [
        "packages/review-heuristic/src/index.ts"
      ],
      "@kb-labs/review-heuristic/*": [
        "packages/review-heuristic/src/*"
      ],
      "@kb-labs/review-llm": [
        "packages/review-llm/src/index.ts"
      ],
      "@kb-labs/review-llm/*": [
        "packages/review-llm/src/*"
      ],
      "@kb-labs/sdk": [
        "../../platform/kb-labs-sdk/packages/sdk/src/index.ts"
      ],
      "@kb-labs/sdk/*": [
        "../../platform/kb-labs-sdk/packages/sdk/src/*"
      ],
      "@kb-labs/shared-cli-ui": [
        "../../platform/kb-labs-shared/packages/shared-cli-ui/src/index.ts"
      ],
      "@kb-labs/shared-cli-ui/*": [
        "../../platform/kb-labs-shared/packages/shared-cli-ui/src/*"
      ]
    }
  }
}
